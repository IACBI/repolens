{
  "include": [
    "src",
    "apps",
    "packages",
    "services",
    "lib",
    "components",
    "pages",
    "app"
  ],
  "exclude": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "coverage",
    ".next",
    "vendor"
  ],
  "outputDir": ".repolens/output",
  "maxFileSizeKb": 300,
  "docs": [
    "README.md",
    "docs/**/*.md"
  ],
  "ai": {
    "enabled": false,
    "provider": "none"
  }
}
