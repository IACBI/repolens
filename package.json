{
  "name": "repolens",
  "version": "0.2.0",
  "description": "A local-first CLI that turns repositories into living documentation.",
  "type": "module",
  "author": "𝓐.𝓒.𝓑",
  "license": "MIT",
  "keywords": [
    "documentation",
    "architecture",
    "onboarding",
    "cli",
    "developer-tools",
    "living-docs",
    "local-first",
    "markdown",
    "mermaid"
  ],
  "bin": {
    "repolens": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
